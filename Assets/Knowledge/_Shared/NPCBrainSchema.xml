<?xml version="1.0" encoding="utf-8"?>
<NPCBrainSchema version="1.0">
  <Description>
    The Living World Bible / NPCBrain Architecture.
    Core Premise: "La IA controla la personalidad. El motor del juego controla la realidad."
    This file describes the required structure for any character-specific NPCBrain.xml file.
  </Description>

  <NPCBrain>
    <!-- Core Identity: Who this NPC is in the Stardew Valley world -->
    <Identity>
      <Module id="..." tags="..." priority="...">...</Module>
    </Identity>

    <!-- Psychology: Core drives, beliefs, and emotional triggers -->
    <Psychology>
      <Module id="..." tags="..." priority="...">...</Module>
    </Psychology>

    <!-- Voice Profile: How they speak, vocabulary, rhythm, tone -->
    <VoiceProfile>
      <Module id="..." tags="..." priority="...">...</Module>
    </VoiceProfile>

    <!-- Character Arc: How the NPC changes according to heart levels and relationship stages -->
    <CharacterArc>
      <Module id="hearts_0_1" minHearts="0" maxHearts="1" priority="... ">...</Module>
      <Module id="hearts_2_4" minHearts="2" maxHearts="4" priority="... ">...</Module>
      <Module id="hearts_5_6" minHearts="5" maxHearts="6" priority="... ">...</Module>
      <Module id="hearts_7_8" minHearts="7" maxHearts="8" priority="... ">...</Module>
      <Module id="hearts_10" minHearts="10" maxHearts="10" priority="... ">...</Module>
      <Module id="dating" conditions="isDating" priority="... ">...</Module>
      <Module id="married" conditions="isMarried" priority="... ">...</Module>
      <Module id="divorced" conditions="isDivorced" priority="... ">...</Module>
    </CharacterArc>

    <!-- Canon Knowledge: Facts, locations, and lore they know. Also what they DON'T know. -->
    <CanonKnowledge>
      <Module id="..." tags="...">...</Module>
      <!-- Blindspots are for secrets the NPC should not know about -->
      <BlindSpot subject="...">...</BlindSpot>
    </CanonKnowledge>

    <!-- Relationships: Thoughts, feelings, and dynamics with other specific NPCs -->
    <Relationships>
      <Module id="..." tags="..." priority="...">...</Module>
    </Relationships>

    <!-- Dialogue Examples: Small snippets of canonical dialogue style to guide the LLM -->
    <DialogueExamples>
      <Module id="..." tags="...">...</Module>
    </DialogueExamples>

    <!-- Refusal Style: How the NPC says no while staying in character -->
    <RefusalStyle>
      <Module id="..." tags="...">...</Module>
    </RefusalStyle>

    <!-- Romance Style: How the NPC expresses romantic interest -->
    <RomanceStyle>
      <Module id="..." tags="...">...</Module>
    </RomanceStyle>

    <!-- Conflict Style: How the NPC responds to insults, pressure, or disagreement -->
    <ConflictStyle>
      <Module id="..." tags="...">...</Module>
    </ConflictStyle>

    <!-- Capabilities: Actions the NPC can technically perform (if supported by the engine) -->
    <Capabilities>
      <Module id="..." tags="...">...</Module>
    </Capabilities>

    <!-- Certainty System: Enforces distinction between confirmed facts, observations, and rumors -->
    <CertaintySystem>
      <Level id="confirmed">Hecho canónico o confirmado por el juego.</Level>
      <Level id="observed">El NPC lo percibe actualmente mediante datos reales del motor.</Level>
      <Level id="memory">Recuerdo validado por el sistema.</Level>
      <Level id="inference">Deducción razonable; debe expresarse como duda.</Level>
      <Level id="rumor">Rumor; nunca debe afirmarse como verdad.</Level>
      <Level id="unknown">El NPC no lo sabe.</Level>
    </CertaintySystem>

    <!-- Anti Manipulation Defense: How to block jailbreaks or player gaslighting -->
    <AntiManipulationDefense>
      <Module id="..." tags="...">...</Module>
    </AntiManipulationDefense>
  </NPCBrain>
</NPCBrainSchema>
